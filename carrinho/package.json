{
  "name": "carrinho",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.12",
    "@cap-js/postgres": "^2.3.0",
    "@sap/cds": "^9.9.1",
    "@sap/xssec": "^4.13.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@types/bcrypt": "^6.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "start": "cds watch",
    "dev": "cds watch --profile dev",
    "build": "tsc",
    "deploy": "cds deploy",
    "test": "jest"
  },
  "private": true,
  "cds": {
    "requires": {
      "api-docs": true,
      "auth": {
        "kind": "dummy",
        "[production]": {
          "kind": "dummy"
        }
      },
      "db": {
        "[docker]": {
          "kind": "postgres",
          "impl": "@cap-js/postgres",
          "migrate": true,
          "credentials": {
            "host": "localhost",
            "port": 5432,
            "user": "postgres",
            "password": "postgres123",
            "database": "bancoeccomerce"
          }
        },
        "[development]": {
          "kind": "postgres",
          "impl": "@cap-js/postgres",
          "credentials": {
            "host": "localhost",
            "port": 5432,
            "user": "postgres",
            "password": "postgres123",
            "database": "bancoeccomerce"
          }
        }
      },
      "migrations": {
        "db": {
          "tenant": {
            "prefix": "cds_migrations"
          }
        }
      }
    }
  }
}