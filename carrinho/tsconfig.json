{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",                    
    "lib": ["ES2020","dom"],
    "outDir": "./dist",
    "types": ["node"], 
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "moduleResolution": "node16" ,
          
  },
  "include": ["srv/**/*", "db/**/*", "auth/jwt-auth.ts"],
  "exclude": ["node_modules", "dist"]
}
